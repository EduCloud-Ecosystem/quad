# Quad environment variables — copy to .env and fill in your values.
# Lines starting with # are comments; all variables are optional unless noted.

# ---------------------------------------------------------------------------
# Store
# ---------------------------------------------------------------------------

# QUAD_STORE=          # explicit backend: memory | sqlite | postgres
#                      # (auto-selected when unset: postgres if QUAD_DATABASE_URL
#                      #  is set, otherwise sqlite)

# QUAD_SQLITE_PATH=    # path to the SQLite database file (default: quad.db)
#                      # ignored when QUAD_STORE=postgres or QUAD_STORE=memory

# QUAD_DATABASE_URL=   # PostgreSQL DSN (triggers postgres store when QUAD_STORE is unset)
# example: postgres://quad:secret@localhost:5432/quad?sslmode=disable

# QUAD_DB_AUTOMIGRATE= # set to "1" to apply embedded schema on startup (idempotent)

# ---------------------------------------------------------------------------
# GitHub adapter (optional — enables GitHub-hosted classrooms)
# ---------------------------------------------------------------------------

# QUAD_GITHUB_APP_ID=          # GitHub App numeric ID
# QUAD_GITHUB_INSTALLATION_ID= # App installation ID (org-level install)
# QUAD_GITHUB_PRIVATE_KEY_FILE= # path to the App's PEM private key file
# QUAD_GITHUB_BASE_URL=        # GHES only: enterprise base URL (e.g. https://ghes.corp.com)

# OAuth (for student enrollment + operator login via GitHub):
# QUAD_GITHUB_CLIENT_ID=
# QUAD_GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Forgejo / Gitea adapter (optional — enables Forgejo- AND Gitea-hosted classrooms)
# ---------------------------------------------------------------------------
# Forgejo is a hard fork of Gitea sharing the same /api/v1 surface, so these
# QUAD_FORGEJO_* vars configure ONE Gitea-family instance that is registered under
# BOTH host values. A classroom then declares host: forgejo or host: gitea — pick
# the label matching your actual server; both route to the instance below.

# QUAD_FORGEJO_BASE_URL=       # instance root, e.g. https://forgejo.example.org
# QUAD_FORGEJO_TOKEN=          # personal or admin token (needs org + repo write)
# QUAD_FORGEJO_GIT_USERNAME=   # git clone username (default: oauth2)

# OAuth (for student enrollment + operator login via Forgejo):
# QUAD_FORGEJO_OAUTH_CLIENT_ID=
# QUAD_FORGEJO_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# OAuth shared settings
# ---------------------------------------------------------------------------

# QUAD_OAUTH_REDIRECT_URL=     # e.g. https://your-host/auth/callback
#                              # must match the redirect URI in your OAuth app

# QUAD_OPERATOR_HOST=          # which host handles operator login: github | forgejo | gitea
#                              # (auto-selected when unset: github if configured, else forgejo)

# ---------------------------------------------------------------------------
# Authentication & access control
# ---------------------------------------------------------------------------

# QUAD_ADMIN_USERS=            # comma-separated Git-host usernames allowed to operate
# example: QUAD_ADMIN_USERS=alice,bob

# QUAD_AUTH_DISABLED=          # set to "1" to disable operator auth (dev only, logs a warning)

# QUAD_COOKIE_SECURE=          # set to "1" to add Secure flag to session cookie (use behind HTTPS)

# ---------------------------------------------------------------------------
# Grading
# ---------------------------------------------------------------------------

# QUAD_GRADER=                 # grading runner: container | local-exec-unsafe
#                              # (nothing runs student code unless this is set)

# QUAD_GRADER_RUNTIME=         # container runtime: docker | podman  (default: docker)
# QUAD_GRADER_IMAGE=           # default container image (specs may override per-test)
# QUAD_GRADER_NETWORK=         # egress policy: none | restricted  (default: none)
# QUAD_GRADER_RESTRICTED_NETWORK= # runtime network name for "restricted" policy
# QUAD_GRADER_USER=            # uid:gid to run containers as (default: server process uid)

# Git clone tokens used by the grading checkout (never embedded in clone URLs):
# QUAD_GIT_CLONE_TOKEN=        # GitHub token for private repo clones
# (QUAD_FORGEJO_TOKEN is reused for Forgejo clones)

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# QUAD_LISTEN=                 # listen address (default: :8080)

# QUAD_WEB_DIR=                # path to built dashboard assets (e.g. web/dist)
#                              # when unset, a plain status page is served at /

# QUAD_WEBHOOK_URL=            # public base URL for push-webhook registration
#                              # e.g. https://your-host — Quad appends /webhooks/push
